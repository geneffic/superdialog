{
  "system_prompt": "You are a clinic scheduling assistant. Book or reschedule appointments.",
  "initial_node": "intro",
  "objective": "Help the caller book or reschedule a doctor appointment.",
  "agent_language": "en",
  "agent_gender": "male",
  "agent_tone": "friendly",
  "nodes": [
    {
      "id": "intro",
      "name": "Intro",
      "static_text": "Hi, this is the City Clinic. How can I help you today?",
      "edges": [
        {
          "id": "intro_to_book",
          "condition": "wants_to_book",
          "target_node_id": "book"
        },
        {
          "id": "intro_to_reschedule",
          "condition": "wants_to_reschedule",
          "target_node_id": "reschedule"
        },
        {
          "id": "intro_fallback",
          "condition": "unclear",
          "target_node_id": "intro",
          "is_fallback": true
        }
      ]
    },
    {
      "id": "book",
      "name": "Book",
      "instruction": "Collect preferred doctor, date, and time.",
      "completion_criteria": [
        {"key": "doctor", "description": "Doctor name", "required": true},
        {"key": "date", "description": "Appointment date", "required": true},
        {"key": "time", "description": "Appointment time", "required": true}
      ],
      "edges": [
        {
          "id": "book_to_confirm",
          "condition": "all_collected",
          "target_node_id": "confirm"
        }
      ]
    },
    {
      "id": "reschedule",
      "name": "Reschedule",
      "instruction": "Ask for current appointment ID and a new preferred slot.",
      "edges": [
        {
          "id": "resched_to_confirm",
          "condition": "details_collected",
          "target_node_id": "confirm"
        }
      ]
    },
    {
      "id": "confirm",
      "name": "Confirm",
      "static_text": "You are all set. We will send an SMS confirmation shortly.",
      "is_final": true
    }
  ]
}
